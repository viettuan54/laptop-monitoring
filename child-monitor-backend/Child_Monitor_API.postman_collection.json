{
  "info": {
    "name": "Child Monitor API",
    "description": "Postman Collection for Child Monitor Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "device_secret",
      "value": "",
      "type": "string"
    },
    {
      "key": "child_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "device_id",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Parent\",\n  \"email\": \"parent@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"parent@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "verify"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"parent@example.com\",\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "forgot-password"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"parent@example.com\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Children",
      "item": [
        {
          "name": "Get Children",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/children",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "children"
              ]
            }
          }
        },
        {
          "name": "Create Child",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/children",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "children"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Child 1\",\n  \"age\": 10\n}"
            }
          }
        },
        {
          "name": "Update Child",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/children/{{child_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "children",
                "{{child_id}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Child 1 Updated\",\n  \"age\": 11\n}"
            }
          }
        },
        {
          "name": "Delete Child",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/children/{{child_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "children",
                "{{child_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Devices",
      "item": [
        {
          "name": "Get Devices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/devices",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "devices"
              ]
            }
          }
        },
        {
          "name": "Register Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/devices",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "devices"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": \"{{child_id}}\",\n  \"device_name\": \"My Laptop\",\n  \"device_uid\": \"uid-12345\"\n}"
            }
          }
        },
        {
          "name": "Rotate Secret",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/devices/{{device_id}}/rotate-secret",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "devices",
                "{{device_id}}",
                "rotate-secret"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Settings",
      "item": [
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/settings/{{child_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "settings",
                "{{child_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/settings/{{child_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "settings",
                "{{child_id}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_locked\": false,\n  \"screen_time_limit\": 120\n}"
            }
          }
        }
      ]
    },
    {
      "name": "5. Parent Logs & Alerts",
      "item": [
        {
          "name": "Get App Logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/logs/app?device_id={{device_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "logs",
                "app"
              ],
              "query": [
                {
                  "key": "device_id",
                  "value": "{{device_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Web Logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/logs/web?device_id={{device_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "logs",
                "web"
              ],
              "query": [
                {
                  "key": "device_id",
                  "value": "{{device_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Alerts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/alerts?device_id={{device_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "alerts"
              ],
              "query": [
                {
                  "key": "device_id",
                  "value": "{{device_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Mark Alert Read",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/alerts/1/read",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "alerts",
                "1",
                "read"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "6. AI Analysis",
      "item": [
        {
          "name": "Get AI Analysis",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/ai-analysis?device_id={{device_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "ai-analysis"
              ],
              "query": [
                {
                  "key": "device_id",
                  "value": "{{device_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Trigger AI Analysis",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/ai-analysis/analyze/{{device_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "ai-analysis",
                "analyze",
                "{{device_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "7. Agent (Device APIs)",
      "item": [
        {
          "name": "Heartbeat",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Device-Secret",
                "value": "{{device_secret}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/agent/heartbeat",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "agent",
                "heartbeat"
              ]
            }
          }
        },
        {
          "name": "Get Config",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "X-Device-Secret",
                "value": "{{device_secret}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/agent/config",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "agent",
                "config"
              ]
            }
          }
        },
        {
          "name": "Agent Post App Log",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Device-Secret",
                "value": "{{device_secret}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/logs/app",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "logs",
                "app"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apps\": [\n    {\n      \"app_name\": \"chrome.exe\",\n      \"duration\": 60\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Agent Post Vision Alert",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Device-Secret",
                "value": "{{device_secret}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/agent/vision-alert",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "agent",
                "vision-alert"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alert_type\": \"posture_warning\",\n  \"confidence\": 0.95\n}"
            }
          }
        }
      ]
    }
  ]
}